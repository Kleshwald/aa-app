{
  "name": "agent-academy",
  "version": "0.1.0",
  "description": "Agent Academy prototype — Angular 20 + Taiga UI 5 + Tailwind, mock backend via HttpInterceptor",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:staging": "ng build --configuration=staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "generate:api": "openapi-typescript api-contract.yaml -o src/app/core/models/api.generated.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,html}": [
      "eslint --fix"
    ],
    "src/**/*.{ts,html,scss,json}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "all",
    "semi": true,
    "arrowParens": "always",
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/service-worker": "^20.3.0",
    "@faker-js/faker": "^10.4.0",
    "@lucide/angular": "^1.16.0",
    "@ng-web-apis/common": "^5.3.0",
    "@ng-web-apis/intersection-observer": "^5.3.0",
    "@ng-web-apis/mutation-observer": "^5.3.0",
    "@ng-web-apis/platform": "^5.3.0",
    "@taiga-ui/addon-commerce": "^5.8.0",
    "@taiga-ui/addon-mobile": "^5.8.0",
    "@taiga-ui/addon-table": "^5.8.0",
    "@taiga-ui/cdk": "^5.8.0",
    "@taiga-ui/core": "^5.8.0",
    "@taiga-ui/event-plugins": "^5.0.0",
    "@taiga-ui/i18n": "^5.8.0",
    "@taiga-ui/icons": "^5.8.0",
    "@taiga-ui/kit": "^5.8.0",
    "@taiga-ui/layout": "^5.8.0",
    "@taiga-ui/polymorpheus": "^5.0.1",
    "@taiga-ui/styles": "^5.8.0",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^20.7.0",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/schematics": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/build": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "angular-eslint": "^20.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.6.4",
    "lint-staged": "^15.5.2",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.0"
  }
}
